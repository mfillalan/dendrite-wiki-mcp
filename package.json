{
  "name": "dendrite-wiki-mcp",
  "version": "0.1.0",
  "description": "Local-first MCP server that gives AI coding agents a living, browser-viewable project wiki and a project-local memory store, so the agent stays oriented and the human stays in control.",
  "type": "module",
  "private": false,
  "main": "dist/src/index.js",
  "bin": {
    "dendrite-wiki-mcp": "dist/src/index.js",
    "dendrite-wiki": "dist/src/cli.js"
  },
  "homepage": "https://github.com/mfillalan/dendrite-wiki-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mfillalan/dendrite-wiki-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/mfillalan/dendrite-wiki-mcp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "docs/wiki/mcp-installation.md",
    "docs/wiki/benchmarking.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "benchmark:snapshot": "tsx src/cli.ts benchmark:snapshot",
    "dev": "tsx src/index.ts",
    "docs:dev": "vitepress dev docs --host 127.0.0.1 --port 5177",
    "docs:serve": "tsx scripts/docs-serve.ts",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --host 127.0.0.1 --port 4177",
    "init": "tsx src/cli.ts init --dev",
    "prepack": "npm run build",
    "review-bridge": "tsx scripts/review-bridge.ts",
    "test": "tsx --test test/**/*.test.ts",
    "wiki:action": "tsx scripts/run-maintenance-action.ts",
    "wiki:refresh": "tsx scripts/refresh-wiki.ts",
    "check": "npm run wiki:refresh && npm run build && npm run test && npm run docs:build"
  },
  "keywords": [
    "agent-memory",
    "ai-agent",
    "ai-coding",
    "claude-code",
    "codex",
    "copilot",
    "cursor",
    "documentation",
    "documentation-automation",
    "living-wiki",
    "llm-wiki",
    "local-first",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "project-memory",
    "vitepress"
  ],
  "author": "Michael Fillalan",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitepress": "latest"
  }
}
