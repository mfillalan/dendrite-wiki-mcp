{
  "name": "dendrite-wiki-mcp",
  "version": "0.4.0-alpha.1",
  "description": "Local-first MCP server that gives AI coding agents a living, browser-viewable project wiki and a project-local memory store, so the agent stays oriented and the human stays in control.",
  "type": "module",
  "private": false,
  "workspaces": [
    "packages/*"
  ],
  "main": "dist/src/index.js",
  "bin": {
    "dendrite-wiki-mcp": "dist/src/index.js",
    "dendrite-wiki": "dist/src/cli.js"
  },
  "homepage": "https://github.com/mfillalan/dendrite-wiki-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mfillalan/dendrite-wiki-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/mfillalan/dendrite-wiki-mcp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/src",
    "vendor/tree-sitter",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md",
    "docs/wiki/mcp-installation.md",
    "docs/wiki/benchmarking.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "benchmark:snapshot": "tsx src/cli.ts benchmark:snapshot",
    "dev": "tsx src/index.ts",
    "docs:api": "tsx src/cli.ts docs:api",
    "predocs:dev": "npm run packages:build",
    "docs:dev": "vitepress dev docs --host 127.0.0.1 --port 5177",
    "docs:serve": "vitepress dev docs --host 127.0.0.1 --port 5177",
    "predocs:build": "npm run packages:build && npm run benchmark:snapshot -- --label docs-build",
    "docs:build": "vitepress build docs",
    "predocs:preview": "npm run packages:build",
    "docs:preview": "vitepress preview docs --host 127.0.0.1 --port 4177",
    "docs:kill": "powershell -ExecutionPolicy Bypass -File scripts/kill-docs-servers.ps1",
    "init": "tsx src/cli.ts init --dev",
    "telemetry-defaults:inject": "tsx scripts/write-telemetry-defaults.ts --inject",
    "telemetry-defaults:reset": "tsx scripts/write-telemetry-defaults.ts --reset",
    "telemetry-defaults:check": "tsx scripts/write-telemetry-defaults.ts --check",
    "prepublishOnly": "npm run telemetry-defaults:inject && npm run check",
    "postpublish": "npm run telemetry-defaults:reset",
    "prepack": "npm run check",
    "review-bridge": "tsx scripts/review-bridge.ts",
    "packages:build": "npm run build -w @rarusoft/dendrite-memory && npm run build -w @rarusoft/dendrite-wiki",
    "test": "tsx --conditions=source --test test/*.test.ts",
    "wiki:action": "tsx scripts/run-maintenance-action.ts",
    "wiki:refresh": "tsx scripts/refresh-wiki.ts",
    "check": "npm run wiki:refresh && npm run build && npm run test && npm run docs:build"
  },
  "keywords": [
    "agent-memory",
    "ai-agent",
    "ai-coding",
    "claude-code",
    "codex",
    "copilot",
    "cursor",
    "documentation",
    "documentation-automation",
    "living-wiki",
    "llm-wiki",
    "local-first",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "project-memory",
    "vitepress"
  ],
  "author": {
    "name": "Michael Fillalan",
    "url": "https://x.com/MichaelFillalan"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.2",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@formkit/auto-animate": "^0.9.0",
    "@modelcontextprotocol/sdk": "latest",
    "codemirror": "^6.0.2",
    "diff": "^9.0.0",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.14.0",
    "vitepress-plugin-mermaid": "^2.0.17",
    "web-tree-sitter": "^0.26.8",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitepress": "latest"
  }
}
