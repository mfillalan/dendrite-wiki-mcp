      "slug": "agent-enforcement-architecture",
      "title": "Agent Enforcement Architecture",
      "path": "docs/wiki/agent-enforcement-architecture.md",
      "metadata": {
        "lifecycle": "active",
        "owner": "Michael Fillalan",
