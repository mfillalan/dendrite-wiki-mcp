# Optional synthesis provider configuration.
DENDRITE_WIKI_SYNTHESIS_PROVIDER=none
DENDRITE_WIKI_SYNTHESIS_TIMEOUT_MS=8000

# Optional local Ollama endpoint used by wiki synthesis when provider=ollama.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b

# Optional OpenAI-compatible HTTP endpoint used by wiki synthesis when provider=cloud.
DENDRITE_WIKI_CLOUD_URL=https://api.example.invalid/v1/chat/completions
DENDRITE_WIKI_CLOUD_MODEL=example-model
DENDRITE_WIKI_CLOUD_API_KEY=

# Future local storage path for wiki memory/index data.
DENDRITE_WIKI_DATA_DIR=./local-data
